{
  "name": "cypherpunk-code",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run docs:build && next build && node scripts/sync-out-branding.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "docs:dev": "rm -rf docs/_book && honkit serve docs --port 4000",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:clean": "rm -rf docs/_book public/doc",
    "branding:repo": "python3 scripts/build-repo-branding.py",
    "security:init": "node scripts/security-vault.mjs init",
    "security:encrypt": "node scripts/security-vault.mjs encrypt",
    "security:export": "node scripts/security-vault.mjs export-b64",
    "audit:catalog": "node scripts/audit-catalog-urls.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sql:turso": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script -o prisma/turso-init.sql",
    "db:init:turso": "node scripts/init-turso.mjs",
    "db:init:turso:analytics": "node scripts/init-turso-analytics.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "is-docker": "^4.0.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "axios": "^1.18.0",
    "valibot": "^1.4.1",
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.6",
    "honkit": "^6.1.4",
    "playwright": "^1.52.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
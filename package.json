{
  "name": "cypherpunk-catalog",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run docs:build && next build",
    "build:pages": "node scripts/build-github-pages.mjs",
    "build:all": "npm run docs:build && npm run build:pages",
    "start": "next start",
    "lint": "eslint",
    "docs:dev": "honkit serve docs --port 4000",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:clean": "rm -rf docs/_book public/doc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sql:turso": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script -o prisma/turso-init.sql",
    "db:init:turso": "node scripts/init-turso.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@solana/wallet-standard-features": "^1.4.0",
    "@solana/wallet-standard-util": "^1.1.3",
    "@wallet-standard/app": "^1.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "bitcoinjs-message": "^2.2.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sats-connect": "^4.2.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "honkit": "^6.1.4",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

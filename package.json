{
  "name": "cypherpunk-code",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run docs:build && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "docs:dev": "rm -rf docs/_book && honkit serve docs --port 4000",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:clean": "rm -rf docs/_book public/doc",
    "security:init": "node scripts/security-vault.mjs init",
    "security:encrypt": "node scripts/security-vault.mjs encrypt",
    "security:export": "node scripts/security-vault.mjs export-b64",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sql:turso": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script -o prisma/turso-init.sql",
    "db:init:turso": "node scripts/init-turso.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/wallet-standard-features": "^1.4.0",
    "@solana/wallet-standard-util": "^1.1.3",
    "@solana/web3.js": "^1.98.4",
    "@wallet-standard/app": "^1.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "is-docker": "^4.0.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tweetnacl": "^1.0.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "axios": "^1.18.0",
    "valibot": "^1.4.1",
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "honkit": "^6.1.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

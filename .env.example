# Database
# Local preview (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production on Vercel (Turso / libSQL — required):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
# One-time production schema: npm run db:init:turso

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"
# Production on Vercel (must match live domain — never leave as .ca):
# AUTH_URL="https://cypherpunk-code.com"

# Developer-only test login (must stay false in production)
DEV_LOGIN_ENABLED="false"

# Security vault (encrypted — local template in .local-private/, never in git)
# Recommended in production:
# SECURITY_VAULT_KEY=""
# SECURITY_VAULT_B64=""

# Admin portal — REQUIRED in production
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
# Or use a bcrypt hash instead of plain password:
# ADMIN_PASSWORD_HASH=""
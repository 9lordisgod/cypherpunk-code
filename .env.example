# Database
# Local preview (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production on Vercel (Turso / libSQL — recommended):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
# Production (PostgreSQL / Neon — alternative):
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# Developer-only test login (must stay false in production)
DEV_LOGIN_ENABLED="false"

# Admin portal
ADMIN_EMAIL="your-email@example.com"
# Prefer bcrypt hash ($2...) in production; plain text works for local preview only
ADMIN_PASSWORD="your-chosen-password"
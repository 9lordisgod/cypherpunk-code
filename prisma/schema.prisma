generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  role          String            @default("learner")
  walletKeyHash String?           @unique
  xHandle       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  progress      ChapterProgress[]
  feedback      Feedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ChapterProgress {
  id           String   @id @default(cuid())
  userId       String
  courseSlug   String
  chapterSlug  String
  chapterTitle String
  courseTitle  String?
  completed    Boolean  @default(false)
  lastReadAt   DateTime @default(now())
  completedAt  DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug, chapterSlug])
  @@index([userId, lastReadAt])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  xHandle   String?
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  visitorId   String
  path        String
  resourceId  String?
  courseSlug  String?
  chapterSlug String?
  signedIn    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([visitorId, createdAt])
  @@index([signedIn, createdAt])
}
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your personal Telegram chat ID (message @userinfobot or /start your bot then check getUpdates)
TELEGRAM_CHAT_ID=123456789

# Hard limit: 2 posts per calendar day (see state/daily.json)
# Run once daily, e.g. cron: 0 9 * * * cd .../marketing-manager && .venv/bin/python main.py

# If api.telegram.org is blocked on your network, use VPN or a proxy:
# HTTPS_PROXY=socks5://127.0.0.1:1080

# Optional: override paths (defaults assume repo layout)
# CYPHERPUNK_DATA_DIR=../../src/data
# CYPHERPUNK_LOGO_PATH=../../public/logo.png